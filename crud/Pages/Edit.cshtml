@page "{id:int}"
@model CrudMySQL.Classic.Pages.EditModel
@{
    ViewData["Title"] = "Modifier un produit - CRUDORY";
}

<div class="container mt-4">
    <h1 class="mb-4">✏️ Modifier le produit #@Model.Produit.Id</h1>
    
    <div class="row">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header bg-warning text-dark">
                    <h5 class="mb-0">Modification du produit</h5>
                </div>
                <div class="card-body">
                    <form method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                        <input type="hidden" asp-for="Produit.Id" />
                        <input type="hidden" asp-for="Produit.DateCreation" />
                        
                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="Produit.Nom" class="form-label"></label>
                                    <input asp-for="Produit.Nom" class="form-control" />
                                    <span asp-validation-for="Produit.Nom" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="Produit.Prix" class="form-label"></label>
                                    <input asp-for="Produit.Prix" class="form-control" type="number" step="0.01" />
                                    <span asp-validation-for="Produit.Prix" class="text-danger"></span>
                                </div>
                            </div>
                        </div>
                        
                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="Produit.Categorie" class="form-label"></label>
                                    <input asp-for="Produit.Categorie" class="form-control" />
                                    <span asp-validation-for="Produit.Categorie" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="Produit.Description" class="form-label"></label>
                                    <input asp-for="Produit.Description" class="form-control" />
                                    <span asp-validation-for="Produit.Description" class="text-danger"></span>
                                </div>
                            </div>
                        </div>
                        
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-success">
                                💾 Enregistrer les modifications
                            </button>
                            <a asp-page="./Index" class="btn btn-secondary">
                                ❌ Annuler
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
