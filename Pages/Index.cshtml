@page
@model IndexModel
@{
    ViewData["Title"] = Model.T("Title") + " - " + Model.AppName();
}

<div class="d-flex flex-column flex-md-row justify-content-between align-items-center mb-4 gap-3">
    <h1>@Model.T("Title")</h1>
    <a asp-page="./Create" class="btn btn-primary">
        @Model.T("AddProduct")
    </a>
</div>

<!-- Statistiques avec couleurs plus vives -->
<div class="stats-grid">
    <div class="stat-card" style="background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%); color: white; border: none;">
        <div class="stat-number" style="color: white;">@Model.Produits.Count()</div>
        <div class="stat-label" style="color: rgba(255,255,255,0.9);">@Model.T("TotalProducts")</div>
    </div>
    <div class="stat-card" style="background: linear-gradient(135deg, #10b981 0%, #059669 100%); color: white; border: none;">
        <div class="stat-number" style="color: white;">@Model.Produits.Sum(p => p.Prix).ToString("C")</div>
        <div class="stat-label" style="color: rgba(255,255,255,0.9);">@Model.T("TotalValue")</div>
    </div>
    <div class="stat-card" style="background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%); color: white; border: none;">
        <div class="stat-number" style="color: white;">@Model.Produits.Select(p => p.Categorie).Distinct().Count()</div>
        <div class="stat-label" style="color: rgba(255,255,255,0.9);">@Model.T("Categories")</div>
    </div>
</div>

<!-- Barre de recherche et filtres -->
<div class="card mb-4">
    <div class="card-body">
        <form method="get" class="row g-3 align-items-end">
            <div class="col-md-4">
                <label class="form-label">@Model.T("Search")</label>
                <div class="input-group">
                    <input type="text" class="form-control" name="searchTerm" value="@Model.SearchTerm" placeholder="@Model.T("SearchPlaceholder")" />
                    <button type="submit" class="btn btn-outline-primary">
                        <i class="fas fa-search"></i>
                    </button>
                </div>
            </div>
            <div class="col-md-3">
                <label class="form-label">@Model.T("SortBy")</label>
                <select class="form-select" name="sortBy">
                    <option value="DateCreation" selected="@(Model.SortBy == "DateCreation")">@Model.T("CreationDate")</option>
                    <option value="Nom" selected="@(Model.SortBy == "Nom")">@Model.T("Name")</option>
                    <option value="Categorie" selected="@(Model.SortBy == "Categorie")">@Model.T("Category")</option>
                    <option value="Prix" selected="@(Model.SortBy == "Prix")">@Model.T("Price")</option>
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label">@Model.T("Order")</label>
                <select class="form-select" name="sortOrder">
                    <option value="desc" selected="@(Model.SortOrder == "desc")">@Model.T("Descending")</option>
                    <option value="asc" selected="@(Model.SortOrder == "asc")">@Model.T("Ascending")</option>
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label d-none">&nbsp;</label>
                <button type="submit" class="btn btn-primary w-100">
                    @Model.T("Apply")
                </button>
            </div>
        </form>
        
        @if (!string.IsNullOrEmpty(Model.SearchTerm))
        {
            <div class="alert alert-info mt-3 mb-0">
                <i class="fas fa-info-circle me-2"></i>
                @Model.T("SearchFor") <strong>"@Model.SearchTerm"</strong> (@Model.TotalCount @Model.T("Results"))
            </div>
        }
    </div>
</div>

<!-- Liste des produits avec pagination -->
<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span>@Model.T("ProductsList")</span>
        <small class="text-muted">@Model.TotalCount @Model.T("Total")</small>
    </div>
    <div class="card-body">
        @if (Model.Produits.Count() == 0)
        {
            <div class="text-center py-5">
                <div class="text-muted mb-3">
                    @if (!string.IsNullOrEmpty(Model.SearchTerm))
                    {
                        @Model.T("NoProductsFoundFor") @Model.SearchTerm
                    }
                    else
                    {
                        @Model.T("NoProductsFound")
                    }
                </div>
                <p class="text-muted">@Model.T("ClickToAdd")</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table">
                    <thead>
                        <tr>
                            <th>@Model.T("ID")</th>
                            <th>@Model.T("Name")</th>
                            <th>@Model.T("Category")</th>
                            <th>@Model.T("Price")</th>
                            <th>@Model.T("Description")</th>
                            <th>@Model.T("Date")</th>
                            <th class="d-mobile-none">@Model.T("Actions")</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var produit in Model.Produits)
                        {
                            <tr>
                                <td><span class="badge bg-dark">@produit.Id</span></td>
                                <td class="font-weight-bold">@produit.Nom</td>
                                <td><span class="badge bg-secondary">@produit.Categorie</span></td>
                                <td class="text-success font-weight-bold">@produit.Prix.ToString("C")</td>
                                <td class="text-muted d-mobile-none">@(produit.Description ?? "-")</td>
                                <td class="text-muted">@produit.DateCreation.ToString("dd/MM/yyyy")</td>
                                <td>
                                    <div class="d-flex gap-2 flex-column flex-md-row">
                                        <a asp-page="./Edit" asp-route-id="@produit.Id" class="btn btn-sm btn-warning">
                                            @Model.T("Edit")
                                        </a>
                                        <button class="btn btn-sm btn-danger" onclick="showDeleteModal(@produit.Id, '@produit.Nom')">
                                            @Model.T("Delete")
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            
            <!-- Pagination -->
            @if (Model.TotalPages > 1)
            {
                <nav aria-label="Pagination" class="mt-4">
                    <ul class="pagination justify-content-center mb-0">
                        <!-- Page précédente -->
                        @if (Model.CurrentPage > 1)
                        {
                            <li class="page-item">
                                <a class="page-link" asp-page="./Index" asp-route-currentPage="@(Model.CurrentPage - 1)" asp-route-searchTerm="@Model.SearchTerm" asp-route-sortBy="@Model.SortBy" asp-route-sortOrder="@Model.SortOrder">
                                    <i class="fas fa-chevron-left"></i> @Model.T("Previous")
                                </a>
                            </li>
                        }
                        else
                        {
                            <li class="page-item disabled">
                                <span class="page-link">
                                    <i class="fas fa-chevron-left"></i> @Model.T("Previous")
                                </span>
                            </li>
                        }

                        <!-- Numéros de pages -->
                        @{
                            var startPage = Math.Max(1, Model.CurrentPage - 2);
                            var endPage = Math.Min(Model.TotalPages, Model.CurrentPage + 2);
                            
                            if (startPage > 1)
                            {
                                <li class="page-item">
                                    <a class="page-link" asp-page="./Index" asp-route-currentPage="1" asp-route-searchTerm="@Model.SearchTerm" asp-route-sortBy="@Model.SortBy" asp-route-sortOrder="@Model.SortOrder">1</a>
                                </li>
                                if (startPage > 2)
                                {
                                    <li class="page-item disabled">
                                        <span class="page-link">...</span>
                                    </li>
                                }
                            }
                            
                            for (int i = startPage; i <= endPage; i++)
                            {
                                <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                                    @if (i == Model.CurrentPage)
                                    {
                                        <span class="page-link">@i</span>
                                    }
                                    else
                                    {
                                        <a class="page-link" asp-page="./Index" asp-route-currentPage="@i" asp-route-searchTerm="@Model.SearchTerm" asp-route-sortBy="@Model.SortBy" asp-route-sortOrder="@Model.SortOrder">@i</a>
                                    }
                                </li>
                            }
                            
                            if (endPage < Model.TotalPages)
                            {
                                if (endPage < Model.TotalPages - 1)
                                {
                                    <li class="page-item disabled">
                                        <span class="page-link">...</span>
                                    </li>
                                }
                                <li class="page-item">
                                    <a class="page-link" asp-page="./Index" asp-route-currentPage="@Model.TotalPages" asp-route-searchTerm="@Model.SearchTerm" asp-route-sortBy="@Model.SortBy" asp-route-sortOrder="@Model.SortOrder">@Model.TotalPages</a>
                                </li>
                            }
                        }

                        <!-- Page suivante -->
                        @if (Model.CurrentPage < Model.TotalPages)
                        {
                            <li class="page-item">
                                <a class="page-link" asp-page="./Index" asp-route-currentPage="@(Model.CurrentPage + 1)" asp-route-searchTerm="@Model.SearchTerm" asp-route-sortBy="@Model.SortBy" asp-route-sortOrder="@Model.SortOrder">
                                    @Model.T("Next") <i class="fas fa-chevron-right"></i>
                                </a>
                            </li>
                        }
                        else
                        {
                            <li class="page-item disabled">
                                <span class="page-link">
                                    @Model.T("Next") <i class="fas fa-chevron-right"></i>
                                </span>
                            </li>
                        }
                    </ul>
                </nav>
                
                <!-- Informations de pagination -->
                <div class="text-center mt-3">
                    <small class="text-muted">
                        @string.Format(Model.T("PageOf"), Model.CurrentPage, Model.TotalPages)
                        (@Model.TotalCount @Model.T("Total"))
                    </small>
                </div>
            }
        }
    </div>
</div>

<!-- Modal de confirmation de suppression -->
<div class="modal fade" id="deleteModal" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="deleteModalLabel">
                    <i class="fas fa-exclamation-triangle text-danger me-2"></i>
                    @Model.T("ConfirmDelete")
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p class="mb-2">@Model.T("ConfirmDeleteMessage")</p>
                <div class="alert alert-warning mb-2">
                    <strong>@Model.T("ProductToDelete"):</strong> <span id="productName"></span>
                </div>
                <small class="text-muted">@Model.T("Irreversible")</small>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                    @Model.T("Cancel")
                </button>
                <button type="button" class="btn btn-danger" id="confirmDeleteBtn">
                    <i class="fas fa-trash me-1"></i>
                    @Model.T("Delete")
                </button>
            </div>
        </div>
    </div>
</div>

<style>
    .pagination .page-link {
        color: var(--primary-color);
        border-color: var(--gray-300);
        padding: 0.5rem 0.75rem;
        font-size: 0.875rem;
    }
    
    .pagination .page-link:hover {
        background-color: var(--gray-50);
        border-color: var(--gray-400);
    }
    
    .pagination .page-item.active .page-link {
        background-color: var(--primary-color);
        border-color: var(--primary-color);
        color: white;
    }
    
    .pagination .page-item.disabled .page-link {
        color: var(--gray-400);
        background-color: var(--gray-50);
        border-color: var(--gray-200);
    }
    
    @@media (max-width: 576px) {
        .pagination .page-link span:not(.fas) {
            display: none;
        }
        
        .pagination .page-link {
            padding: 0.375rem 0.5rem;
            font-size: 0.75rem;
        }
    }
</style>

@section Scripts {
    <script>
        let deleteProductId = null;
        
        // Modal de suppression
        function showDeleteModal(productId, productName) {
            deleteProductId = productId;
            document.getElementById('productName').textContent = productName;
            const modal = new bootstrap.Modal(document.getElementById('deleteModal'));
            modal.show();
        }
        
        document.getElementById('confirmDeleteBtn').addEventListener('click', function() {
            if (deleteProductId) {
                window.location.href = '/Delete?id=' + deleteProductId;
            }
        });
    </script>
}
